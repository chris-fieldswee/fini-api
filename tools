using System.ComponentModel;
using System.Text.Json;
using Meniga.Clients.SmartMoneyApi;
using Microsoft.SemanticKernel;

namespace Meniga.AI.Plugins;

/// <summary>
/// Provides savings automation tools powered by the Smart Money Rules API.
/// Covers: rule listing, creation, simulation, and transfer history.
/// </summary>
public sealed class SmartMoneyRules(SmartMoneyApiClient smrClient)
{
    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 6: list_savings_rules
    // Covers query: #43 (what savings rules do I have active?)
    // API enhancement proposal #F: /rules/instances to return ruleTypeName and parameterDescriptions inline
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("list_savings_rules")]
    [Description(
        "Returns all savings automation rules the user has set up, both active and inactive. " +
        "Use for: 'what savings rules do I have?', 'show my savings automations', 'is my round-up rule active?'. " +
        "Returns rule type, parameters, and active status.")]
    public async Task<string> ListSavingsRules(
        [Description("Filter by status: 'active', 'inactive', or 'all'. Default: 'all'.")] string status = "all")
    {
        try
        {
            var response = await smrClient.User.Smartmoney.V1.Rules.Instances.GetAsync();
            var instances = response?.Data ?? [];

            if (instances.Count == 0)
                return Serialize(new { status = "empty", data = new { rules = Array.Empty<object>() }, meta = new { message = "No savings rules found." } });

            var filtered = status switch
            {
                "active"   => instances.Where(r => r.IsActive == true).ToList(),
                "inactive" => instances.Where(r => r.IsActive != true).ToList(),
                _          => instances
            };

            // API ENHANCEMENT PROPOSAL #F:
            // GET /rules/instances currently returns ruleDefinitionType as a string enum
            // and parameters as an opaque key-value map.
            // Proposal: add 'ruleTypeName' (human-readable label) and 'parameterDescriptions'
            // (a map of paramName → human-readable description) to RuleInstanceReadModel.
            // Example: for roundUpRule, parameters might be { "roundingAmount": "0.5" }
            // but Fini needs to know this means "round up to nearest €0.50".
            // Until implemented, we map known rule types and parameters here.

            var mapped = filtered.Select(r => new
            {
                id              = r.Id,
                name            = r.Name ?? DescribeRuleType(r.RuleDefinitionType),
                ruleType        = r.RuleDefinitionType?.ToString(),
                ruleTypeName    = DescribeRuleType(r.RuleDefinitionType),
                isActive        = r.IsActive,
                deactivatedDate = r.DeactivatedDate,
                parameters      = r.Parameters,
                parameterSummary = DescribeParameters(r.RuleDefinitionType, r.Parameters)
            }).ToList();

            return Serialize(new
            {
                status = "ok",
                data   = new
                {
                    rules        = mapped,
                    activeCount  = mapped.Count(r => r.isActive == true),
                    inactiveCount= mapped.Count(r => r.isActive != true)
                },
                meta = new { statusFilter = status, totalCount = mapped.Count }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 7: create_savings_rule
    // Covers queries: #42 (round-up), #44 (income %), #45 (guilty pleasure), #46 (interval)
    // API enhancement proposal #G: Unified POST /rules/instances endpoint
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("create_savings_rule")]
    [Description(
        "Creates a new savings automation rule. Supports four rule types: " +
        "'roundup' (save spare change on every purchase), " +
        "'income_percentage' (save X% of every income), " +
        "'guilty_pleasure' (save X amount every time you spend on a category), " +
        "'interval' (transfer X amount every week/month). " +
        "Always present the rule details to the user and confirm before calling this tool. " +
        "Returns the created rule ID and summary.")]
    public async Task<string> CreateSavingsRule(
        [Description("Rule type: 'roundup', 'income_percentage', 'guilty_pleasure', or 'interval'.")] string ruleType,
        [Description("For roundup: rounding amount (e.g. 0.5 = round to nearest 50 cents, 1.0 = round to nearest euro). " +
                     "For income_percentage: percentage as decimal (e.g. 0.10 = 10%). " +
                     "For guilty_pleasure: amount to save per trigger. " +
                     "For interval: amount to transfer per interval.")] double amount,
        [Description("For interval rules: frequency in days (e.g. 7 = weekly, 30 = monthly). Ignored for other rule types.")] int? intervalDays = null,
        [Description("For guilty_pleasure rules: category ID to trigger on. Required for guilty_pleasure rules.")] int? categoryId = null,
        [Description("Name for the rule. Optional — a default name will be generated if omitted.")] string? name = null)
    {
        try
        {
            // API ENHANCEMENT PROPOSAL #G:
            // Currently, creating a rule requires calling a different endpoint per rule type:
            // POST /rules/instances/roundup, /income-percentage, /guilty-pleasure, /interval.
            // This forces tools (and LLMs) to know the exact endpoint per type.
            // Proposal: a unified POST /rules/instances endpoint that accepts { ruleType, parameters }
            // and routes internally. This is a common pattern in modern APIs and reduces
            // the number of endpoints Fini's tool needs to know about from 4 to 1.
            // Until implemented, we route internally here.

            return ruleType.ToLower() switch
            {
                "roundup"           => await CreateRoundUpRule(amount, name),
                "income_percentage" => await CreateIncomePercentageRule(amount, name),
                "guilty_pleasure"   => await CreateGuiltyPleasureRule(amount, categoryId, name),
                "interval"          => await CreateIntervalRule(amount, intervalDays, name),
                _ => Serialize(new
                {
                    status = "error",
                    error  = new
                    {
                        reason  = "invalid_rule_type",
                        message = $"Unknown rule type '{ruleType}'. Valid types: roundup, income_percentage, guilty_pleasure, interval."
                    }
                })
            };
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    private async Task<string> CreateRoundUpRule(double roundingAmount, string? name)
    {
        var response = await smrClient.User.Smartmoney.V1.Rules.Instances.Roundup.PostAsync(new()
        {
            Name       = name ?? $"Round-up (nearest €{roundingAmount:F2})",
            Parameters = new() { RoundingAmount = roundingAmount }
        });

        return Serialize(new
        {
            status = "ok",
            data   = new
            {
                ruleId       = response?.Data?.FirstOrDefault()?.Id,
                ruleType     = "roundup",
                description  = $"Round-up savings active: every purchase will be rounded up to the nearest €{roundingAmount:F2} and the difference saved."
            },
            meta = new { note = "Rule is active immediately. Use list_savings_rules to verify." }
        });
    }

    private async Task<string> CreateIncomePercentageRule(double percentage, string? name)
    {
        var response = await smrClient.User.Smartmoney.V1.Rules.Instances.Incomepercantage.PostAsync(new()
        {
            Name       = name ?? $"Save {percentage * 100:F0}% of income",
            Parameters = new() { Percentage = percentage }
        });

        return Serialize(new
        {
            status = "ok",
            data   = new
            {
                ruleId      = response?.Data?.FirstOrDefault()?.Id,
                ruleType    = "income_percentage",
                description = $"{percentage * 100:F0}% of each income payment will be automatically transferred to savings."
            },
            meta = new { note = "Rule triggers on each detected income transaction." }
        });
    }

    private async Task<string> CreateGuiltyPleasureRule(double amount, int? categoryId, string? name)
    {
        if (!categoryId.HasValue)
            return Serialize(new { status = "error", error = new { reason = "missing_parameter", message = "categoryId is required for guilty_pleasure rules. Resolve the category first using the category search." } });

        var response = await smrClient.User.Smartmoney.V1.Rules.Instances.Guiltypleasure.PostAsync(new()
        {
            Name       = name ?? $"Guilty pleasure saving (category {categoryId})",
            Parameters = new() { Amount = amount, CategoryId = categoryId.Value }
        });

        return Serialize(new
        {
            status = "ok",
            data   = new
            {
                ruleId      = response?.Data?.FirstOrDefault()?.Id,
                ruleType    = "guilty_pleasure",
                description = $"€{amount:F2} will be saved every time a transaction is detected in category {categoryId}."
            },
            meta = new { note = "Use list_savings_rules to verify the rule is active." }
        });
    }

    private async Task<string> CreateIntervalRule(double amount, int? intervalDays, string? name)
    {
        if (!intervalDays.HasValue)
            return Serialize(new { status = "error", error = new { reason = "missing_parameter", message = "intervalDays is required for interval rules (e.g. 7 = weekly, 30 = monthly)." } });

        var response = await smrClient.User.Smartmoney.V1.Rules.Instances.Interval.PostAsync(new()
        {
            Name       = name ?? $"Save €{amount:F0} every {intervalDays} days",
            Parameters = new() { Amount = amount, IntervalDays = intervalDays.Value }
        });

        return Serialize(new
        {
            status = "ok",
            data   = new
            {
                ruleId      = response?.Data?.FirstOrDefault()?.Id,
                ruleType    = "interval",
                description = $"€{amount:F2} will be transferred to savings every {intervalDays} days."
            },
            meta = new { note = "First transfer will occur at the next interval." }
        });
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 8: simulate_savings_rule
    // Covers query: #47 (how much would I save if I set up this rule?)
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("simulate_savings_rule")]
    [Description(
        "Simulates how much a savings rule would save over a time period without creating it. " +
        "Use for: 'how much would I save with round-ups?', 'what would 10% income savings look like over 6 months?', " +
        "'show me the impact of setting up this rule'. Returns projected savings amount and timeline.")]
    public async Task<string> SimulateSavingsRule(
        [Description("Rule type to simulate: 'roundup', 'income_percentage', 'guilty_pleasure', or 'interval'.")] string ruleType,
        [Description("Rule amount (same meaning as in create_savings_rule).")] double amount,
        [Description("Simulation period in months. Default: 6.")] int months = 6,
        [Description("Interval days (for interval rules only).")] int? intervalDays = null,
        [Description("Category ID (for guilty_pleasure rules only).")] int? categoryId = null)
    {
        try
        {
            // Map our friendly rule type to SMR's ruleDefinitionType
            var smrRuleType = ruleType.ToLower() switch
            {
                "roundup"           => "RoundUp",
                "income_percentage" => "IncomePercentage",
                "guilty_pleasure"   => "GuiltyPleasure",
                "interval"          => "Interval",
                _                   => null
            };

            if (smrRuleType == null)
                return Serialize(new { status = "error", error = new { reason = "invalid_rule_type", message = $"Unknown rule type '{ruleType}'." } });

            var now    = DateTimeOffset.UtcNow;
            var endDate = now.AddMonths(months);

            var request = new Meniga.Clients.SmartMoneyApi.Models.SimulationRulesRequest
            {
                Rules = [new()
                {
                    RuleDefinitionType = smrRuleType,
                    Parameters         = BuildSimulationParameters(ruleType, amount, intervalDays, categoryId)
                }],
                Period = new()
                {
                    From = now,
                    To   = endDate
                }
            };

            var response = await smrClient.User.Smartmoney.V1.Rules.Simulation.PostAsync(request);
            var results  = response?.Data ?? [];
            var result   = results.FirstOrDefault();

            if (result == null)
                return Serialize(new { status = "empty", meta = new { message = "Simulation returned no results." } });

            return Serialize(new
            {
                status = "ok",
                data   = new
                {
                    ruleType            = ruleType,
                    simulationPeriodMonths = months,
                    projectedTotalSavings = result.TotalAmount,
                    currency            = result.Currency,
                    monthlyBreakdown    = result.Metadata?.Select(m => new
                    {
                        period = m.Period,
                        amount = m.Amount
                    })
                },
                meta = new
                {
                    simulatedFrom = now.ToString("yyyy-MM-dd"),
                    simulatedTo   = endDate.ToString("yyyy-MM-dd"),
                    note          = "Simulation is based on your recent transaction history. Actual savings will vary."
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 9: get_savings_rule_transfers
    // Covers query: #48 (how much have I saved through my rules?)
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("get_savings_rule_transfers")]
    [Description(
        "Returns the history of actual savings transfers made by automation rules. " +
        "Use for: 'how much has my round-up rule saved?', 'show me transfers from my savings rules', " +
        "'is my savings automation working?'. Returns total saved and individual transfers per rule.")]
    public async Task<string> GetSavingsRuleTransfers(
        [Description("Filter by rule type: 'roundup', 'income_percentage', 'guilty_pleasure', 'interval', or 'all'. Default: 'all'.")] string ruleType = "all",
        [Description("Start date in YYYY-MM-DD format. Defaults to 6 months ago.")] string? dateFrom = null,
        [Description("End date in YYYY-MM-DD format. Defaults to today.")] string? dateTo = null)
    {
        var now  = DateTimeOffset.UtcNow;
        var from = TryParseDate(dateFrom) ?? now.AddMonths(-6);
        var to   = TryParseDate(dateTo)   ?? now;

        try
        {
            var ruleTypesParam = ruleType.ToLower() switch
            {
                "roundup"           => new[] { "RoundUp" },
                "income_percentage" => new[] { "IncomePercentage" },
                "guilty_pleasure"   => new[] { "GuiltyPleasure" },
                "interval"          => new[] { "Interval" },
                "all"               => null,
                _                   => null
            };

            var response = await smrClient.User.Smartmoney.V1.Transfers.GetAsync(req =>
            {
                req.QueryParameters.DateFrom = from.ToString("yyyy-MM-dd");
                req.QueryParameters.DateTo   = to.ToString("yyyy-MM-dd");
                if (ruleTypesParam != null)
                    req.QueryParameters.RuleTypes = ruleTypesParam;
            });

            var transfers = response?.Data ?? [];

            if (transfers.Count == 0)
                return Serialize(new { status = "empty", data = new { transfers = Array.Empty<object>(), totalSaved = 0 }, meta = new { message = "No savings rule transfers found for this period." } });

            // Group by rule instance for per-rule totals
            var byRule = transfers
                .GroupBy(t => new { t.RuleInstanceId, t.RuleInstanceName })
                .Select(g => new
                {
                    ruleInstanceId   = g.Key.RuleInstanceId,
                    ruleInstanceName = g.Key.RuleInstanceName,
                    totalSaved       = g.Sum(t => t.Amount ?? 0),
                    currency         = g.FirstOrDefault()?.Currency,
                    transferCount    = g.Count(),
                    transfers        = g.OrderByDescending(t => t.TransferDate).Select(t => new
                    {
                        amount              = t.Amount,
                        currency            = t.Currency,
                        transferDate        = t.TransferDate?.ToString("yyyy-MM-dd"),
                        sourceTransactionId = t.SourceTransactionId
                    }).ToList()
                }).ToList();

            // Overall totals by currency
            var totalsByCurrency = transfers
                .GroupBy(t => t.Currency ?? "EUR")
                .Select(g => new { currency = g.Key, totalSaved = g.Sum(t => t.Amount ?? 0) });

            return Serialize(new
            {
                status = "ok",
                data   = new
                {
                    byRule,
                    totalsByCurrency,
                    totalTransferCount = transfers.Count
                },
                meta = new
                {
                    dateFrom   = from.ToString("yyyy-MM-dd"),
                    dateTo     = to.ToString("yyyy-MM-dd"),
                    ruleFilter = ruleType
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Private helpers
    // ─────────────────────────────────────────────────────────────────────────

    private static DateTimeOffset? TryParseDate(string? value) =>
        DateTimeOffset.TryParse(value, out var d) ? d : null;

    private static string Serialize(object obj) =>
        JsonSerializer.Serialize(obj, new JsonSerializerOptions { WriteIndented = false });

    private static string DescribeRuleType(dynamic? ruleType) => ruleType?.ToString() switch
    {
        "roundUpRule"          => "Round-up savings",
        "intervalRule"         => "Regular interval transfer",
        "guiltyPleasureRule"   => "Guilty pleasure savings",
        "percentageRule"       => "Percentage savings",
        "incomePercentageRule" => "Income percentage savings",
        _                      => ruleType?.ToString() ?? "Unknown rule"
    };

    private static string DescribeParameters(dynamic? ruleType, dynamic? parameters)
    {
        if (parameters == null) return "No parameters available";
        return ruleType?.ToString() switch
        {
            "roundUpRule"          => $"Rounds up each purchase to the nearest €{parameters.GetValueOrDefault("roundingAmount", "?")}",
            "incomePercentageRule" => $"Saves {parameters.GetValueOrDefault("percentage", "?")}% of each income",
            "intervalRule"         => $"Transfers €{parameters.GetValueOrDefault("amount", "?")} every {parameters.GetValueOrDefault("intervalDays", "?")} days",
            "guiltyPleasureRule"   => $"Saves €{parameters.GetValueOrDefault("amount", "?")} per spend in category {parameters.GetValueOrDefault("categoryId", "?")}",
            _                      => "See parameters field for details"
        };
    }

    private static Dictionary<string, object> BuildSimulationParameters(string ruleType, double amount, int? intervalDays, int? categoryId) =>
        ruleType.ToLower() switch
        {
            "roundup"           => new() { ["roundingAmount"] = amount },
            "income_percentage" => new() { ["percentage"]     = amount },
            "interval"          => new() { ["amount"] = amount, ["intervalDays"] = intervalDays ?? 30 },
            "guilty_pleasure"   => new() { ["amount"] = amount, ["categoryId"] = categoryId ?? 0 },
            _                   => new() { ["amount"] = amount }
        };
}
