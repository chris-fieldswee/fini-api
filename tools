transfer{(transferCandidates.Count != 1 ? "s" : "")})");
result.AppendLine("
---
");
// Show each transfer
foreach (var (transaction, confidence, transferType) in
transferCandidates.OrderByDescending(t => t.Transaction.Date))
{
result.AppendLine($"{transaction.Date!.Value:yyyy-MM-dd}");
result.AppendLine($"+{transaction.Amount!.Value:F2} {transaction.Currency ??
"EUR"}");
if (!string.IsNullOrWhiteSpace(transaction.Text))
{
result.AppendLine($"From: {transaction.Text}");
}
result.AppendLine($"Type: {transferType}");
// Show counterparty identifier if available
if (!string.IsNullOrWhiteSpace(transaction.CounterpartyAccountIdentifier))
{
result.AppendLine($"Reference: {transaction.CounterpartyAccountIdentifier}");
else if (!string.IsNullOrWhiteSpace(transaction.BankId))
result.AppendLine($"Reference: {transaction.BankId}");
}
{
}
{
// Show ParsedData sender info if available
if (transaction.ParsedData != null)
var senderData = transaction.ParsedData
.Where(pd => pd.Key != null &&
(pd.Key.Contains("sender"
