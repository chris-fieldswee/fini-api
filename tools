using System.ComponentModel;
using System.Text.Json;
using Meniga.Clients.CashflowApi;
using Meniga.Clients.UserApi;
using Microsoft.SemanticKernel;

namespace Meniga.AI.Plugins;

/// <summary>
/// Provides cashflow planning tools powered by the CFA API.
/// Covers: upcoming payments, balance projection, recurring patterns, subscriptions, cashflow forecast.
/// </summary>
public sealed class CashflowAssistant(
    CashflowApiClient cashflowClient,
    UserApiClient userApiClient)
{
    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 1: list_upcoming_payments
    // Covers queries: #29 (upcoming bills), #30 (cover bills?), #39 (save capacity), #50 (disposable income)
    // API enhancement proposal #A: CFA /upcoming to return categoryName inline (avoids separate category lookup)
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("list_upcoming_payments")]
    [Description(
        "Returns a structured list of the user's upcoming payments and expected income " +
        "within a specified date range. Use for: 'what bills do I have coming up?', " +
        "'will I have enough money this month?', 'what do I owe before payday?'. " +
        "Returns open bills and expected income separately so Fini can compute coverage and disposable income.")]
    public async Task<string> ListUpcomingPayments(
        [Description("Start date in YYYY-MM-DD format. Defaults to today if omitted.")] string? dateFrom,
        [Description("End date in YYYY-MM-DD format. Defaults to end of current month if omitted.")] string? dateTo,
        [Description("Filter: 'expenses' for bills only, 'income' for expected income only, 'all' for both. Default: 'all'.")] string filter = "all",
        [Description("Account ID to scope to a specific account. Optional — omit for all accounts.")] string? accountId = null)
    {
        var now = DateTimeOffset.UtcNow;
        var from = TryParseDate(dateFrom) ?? now;
        var to   = TryParseDate(dateTo)  ?? new DateTimeOffset(now.Year, now.Month, 1, 0, 0, 0, TimeSpan.Zero).AddMonths(1).AddDays(-1);

        try
        {
            // Build category type filter
            // API ENHANCEMENT PROPOSAL #A:
            // CFA /upcoming should support a single 'categoryTypes' param that maps to
            // Meniga's internal CategoryType enum (Expenses, Income, Savings, Excluded).
            // Currently this param exists but not all deployments honour it consistently.
            // When fully supported, this replaces the client-side split below.
            var categoryTypesParam = filter switch
            {
                "expenses" => "Expenses",
                "income"   => "Income",
                "all"      => null, // no filter — return both
                _          => null
            };

            var response = await cashflowClient.User.Cashflow.V2.Upcoming.GetAsync(req =>
            {
                req.QueryParameters.DateFrom = from;
                req.QueryParameters.DateTo   = to;
                req.QueryParameters.PaymentStatus = "Open";
                req.QueryParameters.Sources       = "Detected,ScheduledPayment,Invoice,Manual";
                if (categoryTypesParam != null)
                    req.QueryParameters.CategoryTypes = categoryTypesParam;
                if (accountId != null)
                    req.QueryParameters.AccountIds = accountId;
                req.QueryParameters.IncludeDetails = true;
                req.QueryParameters.Take = 200;
            });

            var upcomings = response?.Data ?? [];

            if (upcomings.Count == 0)
                return Serialize(new { status = "empty", data = new { bills = Array.Empty<object>(), income = Array.Empty<object>() }, meta = new { dateFrom = from.ToString("yyyy-MM-dd"), dateTo = to.ToString("yyyy-MM-dd"), message = "No upcoming transactions found for this period." } });

            // Split into bills (expenses) and income
            // A positive amountInCurrency = income/receivable; negative = expense/bill
            // Also check isReceivable on embedded scheduledPayment detail when available
            var bills = upcomings
                .Where(u => IsExpense(u))
                .Select(u => MapUpcoming(u, "bill"))
                .ToList();

            var income = upcomings
                .Where(u => IsIncome(u))
                .Select(u => MapUpcoming(u, "income"))
                .ToList();

            // Compute summary totals per currency
            var billsByCurrency   = bills.GroupBy(b => b.Currency).Select(g => new { currency = g.Key, total = g.Sum(b => b.Amount) });
            var incomeByCurrency  = income.GroupBy(i => i.Currency).Select(g => new { currency = g.Key, total = g.Sum(i => i.Amount) });

            return Serialize(new
            {
                status = "ok",
                data   = new { bills, income },
                meta   = new
                {
                    dateFrom       = from.ToString("yyyy-MM-dd"),
                    dateTo         = to.ToString("yyyy-MM-dd"),
                    billsCount     = bills.Count,
                    incomeCount    = income.Count,
                    billTotals     = billsByCurrency,
                    incomeTotals   = incomeByCurrency,
                    // API ENHANCEMENT NOTE: currently categoryName is not returned by CFA /upcoming.
                    // Proposal #A asks for categoryName inline so the disclaimer below is not needed.
                    disclaimer     = "Category names are resolved from cached category list. Names reflect Meniga's categorisation."
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 2: project_balance
    // Covers queries: #31 (safe to spend), #32 (overdraft risk), #33 (end-of-month balance)
    // API enhancement proposal #B: Return per-day income/expense breakdown in balance projection
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("project_balance")]
    [Description(
        "Returns the day-by-day projected balance from today until a target date, " +
        "accounting for all upcoming payments and expected income. " +
        "Use for: 'what will my balance be at end of month?', 'will I go overdrawn?', " +
        "'how much can I safely spend?'. Returns the full daily curve plus the lowest projected balance.")]
    public async Task<string> ProjectBalance(
        [Description("Target end date in YYYY-MM-DD format. Defaults to end of current month.")] string? dateTo,
        [Description("Account IDs to include (comma-separated). Optional — omit for all accounts.")] string? accountIds = null,
        [Description("If true, uses the account's available amount (including overdraft limit) rather than raw balance. Default: true.")] bool useAvailableAmount = true)
    {
        var now = DateTimeOffset.UtcNow;
        var to  = TryParseDate(dateTo) ?? new DateTimeOffset(now.Year, now.Month, 1, 0, 0, 0, TimeSpan.Zero).AddMonths(1).AddDays(-1);

        try
        {
            var response = await cashflowClient.User.Cashflow.V2.Upcoming.Balances.GetAsync(req =>
            {
                req.QueryParameters.DateTo             = to;
                req.QueryParameters.UseAvailableAmount = useAvailableAmount;
                // Include overdue upcomings from start of month for accurate projection
                req.QueryParameters.IncludeOverdueFromDate = new DateTimeOffset(now.Year, now.Month, 1, 0, 0, 0, TimeSpan.Zero);
                if (accountIds != null)
                    req.QueryParameters.AccountIds = accountIds;
            });

            var projection = response?.Data;
            if (projection == null)
                return Serialize(new { status = "empty", meta = new { message = "No balance projection data available." } });

            var dailyBalances = projection.BalanceDates ?? [];

            // Find the minimum projected balance and its date (overdraft risk signal)
            var minEntry = dailyBalances.OrderBy(d => d.EndOfDayBalance).FirstOrDefault();

            // API ENHANCEMENT PROPOSAL #B:
            // The current /upcoming/balances response includes endOfDayBalance, income, expenses per day.
            // Proposal: also return cumulativeExpenses and cumulativeIncome to date so
            // Fini can answer "how much will I have spent by day X?" without client-side aggregation.
            // Also propose: a 'safeToSpend' field = currentBalance - sum(openBills) as a pre-computed value.

            return Serialize(new
            {
                status = "ok",
                data   = new
                {
                    startBalance = projection.StartBalance,
                    endBalance   = projection.EndBalance,
                    currency     = projection.Currency,
                    dailyProjection = dailyBalances.Select(d => new
                    {
                        date          = d.Date?.ToString("yyyy-MM-dd"),
                        endOfDayBalance = d.EndOfDayBalance,
                        expectedIncome   = d.Income,
                        expectedExpenses = d.Expenses
                    }),
                    lowestProjectedBalance = new
                    {
                        amount = minEntry?.EndOfDayBalance,
                        date   = minEntry?.Date?.ToString("yyyy-MM-dd"),
                        isNegative = (minEntry?.EndOfDayBalance ?? 0) < 0
                    }
                },
                meta = new
                {
                    projectedFrom  = now.ToString("yyyy-MM-dd"),
                    projectedTo    = to.ToString("yyyy-MM-dd"),
                    useAvailableAmount,
                    note = "Balance projection includes all open upcoming transactions (detected recurring, scheduled payments, invoices, and manual entries)."
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 3: list_subscriptions
    // Covers queries: #27 (what subscriptions do I have?), #28 (how much am I spending on subscriptions?)
    // API enhancement proposal #C: /upcoming/subscriptions to return next billing date
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("list_subscriptions")]
    [Description(
        "Returns all detected subscriptions and their costs. " +
        "Use for: 'what subscriptions do I have?', 'how much am I spending on streaming services?', " +
        "'list my recurring memberships'. Includes subscription name, amount, frequency, and estimated monthly cost.")]
    public async Task<string> ListSubscriptions()
    {
        try
        {
            var response = await cashflowClient.User.Cashflow.V2.Upcoming.Subscriptions.GetAsync(req =>
            {
                req.QueryParameters.Take = 100;
            });

            var subscriptions = response?.Data ?? [];

            if (subscriptions.Count == 0)
                return Serialize(new { status = "empty", data = new { subscriptions = Array.Empty<object>() }, meta = new { message = "No subscriptions detected." } });

            // Map subscriptions with estimated monthly cost
            var mapped = subscriptions.Select(s =>
            {
                var monthlyEstimate = EstimateMonthlyAmount(s.AmountInCurrency ?? 0, s.Pattern);
                return new
                {
                    id              = s.Id,
                    name            = s.Text ?? "Unknown subscription",
                    amount          = s.AmountInCurrency,
                    currency        = s.CurrencyCode,
                    frequency       = DescribeFrequency(s.Pattern),
                    estimatedMonthlyCost = monthlyEstimate,
                    categoryId      = s.CategoryId,
                    status          = s.Status?.ToString(),
                    isWatched       = s.IsWatched,
                    // API ENHANCEMENT PROPOSAL #C:
                    // /upcoming/subscriptions should return 'nextBillingDate' as a computed field.
                    // Currently, to get the next billing date you must query /upcoming filtered by recurringPatternId.
                    // Proposal: add nextBillingDate (DateTimeOffset?) to the subscription response model.
                    // This would eliminate a follow-up call for "when is Netflix charged next?".
                    nextBillingDate = (string?)null // Will be populated once proposal #C is implemented
                };
            }).ToList();

            // Group totals by currency
            var totalsByCurrency = mapped
                .GroupBy(s => s.currency)
                .Select(g => new
                {
                    currency             = g.Key,
                    estimatedMonthlyTotal = g.Sum(s => s.estimatedMonthlyCost),
                    estimatedAnnualTotal  = g.Sum(s => s.estimatedMonthlyCost) * 12
                });

            return Serialize(new
            {
                status = "ok",
                data   = new { subscriptions = mapped },
                meta   = new
                {
                    count            = mapped.Count,
                    totalsByCurrency,
                    note             = "Monthly cost is estimated from billing frequency. Annual subscriptions are divided by 12.",
                    disclaimer       = "Subscriptions are auto-detected from recurring payment patterns. Some may be missing or incorrectly identified."
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 4: list_recurring_patterns
    // Covers queries: #34 (what recurring payments detected?), #35 (when is next salary?)
    // API enhancement proposal #D: /upcoming/recurring to return nextOccurrenceDate
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("list_recurring_patterns")]
    [Description(
        "Returns all detected recurring payment patterns including bills and expected income. " +
        "Use for: 'what regular payments have been detected?', 'when is my next salary?', " +
        "'what do I pay automatically every month?'. " +
        "Filter by type: 'expenses' for recurring bills, 'income' for recurring income like salary.")]
    public async Task<string> ListRecurringPatterns(
        [Description("Filter by category type: 'expenses', 'income', or 'all'. Default: 'all'.")] string filter = "all",
        [Description("Filter by status: 'active' (Accepted + Suggested), 'accepted', 'suggested', or 'all'. Default: 'active'.")] string status = "active")
    {
        try
        {
            var statusParam = status switch
            {
                "active"    => "Accepted,Suggested",
                "accepted"  => "Accepted",
                "suggested" => "Suggested",
                "all"       => null,
                _           => "Accepted,Suggested"
            };

            var categoryTypesParam = filter switch
            {
                "expenses" => "Expenses",
                "income"   => "Income",
                "all"      => null,
                _          => null
            };

            var response = await cashflowClient.User.Cashflow.V2.Upcoming.Recurring.GetAsync(req =>
            {
                if (statusParam != null)        req.QueryParameters.Statuses      = statusParam;
                if (categoryTypesParam != null) req.QueryParameters.CategoryTypes = categoryTypesParam;
                req.QueryParameters.Take = 200;
            });

            var patterns = response?.Data ?? [];

            if (patterns.Count == 0)
                return Serialize(new { status = "empty", data = new { patterns = Array.Empty<object>() }, meta = new { message = "No recurring patterns found." } });

            var mapped = patterns.Select(p => new
            {
                id              = p.Id,
                name            = p.Text ?? "Unknown",
                amount          = p.AmountInCurrency,
                currency        = p.CurrencyCode,
                frequency       = DescribeFrequency(p.Pattern),
                categoryId      = p.CategoryId,
                isSubscription  = p.IsSubscription,
                status          = p.Status?.ToString(),
                type            = p.Type?.ToString(),
                // API ENHANCEMENT PROPOSAL #D:
                // /upcoming/recurring should return 'nextOccurrenceDate' as a server-computed field.
                // Currently, deriving the next occurrence requires parsing the cron expression client-side,
                // which is error-prone and duplicates logic already in the CFA engine.
                // Proposal: add nextOccurrenceDate (DateTimeOffset?) to RecurringPatternModel.
                // This directly answers "when is my next salary?" without a follow-up /upcoming call.
                nextOccurrenceDate = (string?)null, // Populated once proposal #D is implemented
                cronExpression  = p.Pattern?.CronExpression
            }).ToList();

            // Separate income patterns (for salary timing queries)
            var incomePatterns  = mapped.Where(p => !p.isSubscription && p.amount > 0).ToList();
            var expensePatterns = mapped.Where(p => p.amount  < 0 || p.amount == 0).ToList();

            return Serialize(new
            {
                status = "ok",
                data   = new
                {
                    all              = mapped,
                    incomePatterns,
                    expensePatterns,
                    subscriptionCount = mapped.Count(p => p.isSubscription)
                },
                meta = new
                {
                    totalCount = mapped.Count,
                    statusFilter = status,
                    categoryFilter = filter,
                    note = "nextOccurrenceDate will be available once CFA API enhancement #D is implemented. Until then, use list_upcoming_payments with a future date range to find specific next occurrences."
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 5: get_cashflow_forecast
    // Covers query: #36 (expected income vs expenses next month)
    // API enhancement proposal #E: CFA /upcoming/series to support income vs expense split
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("get_cashflow_forecast")]
    [Description(
        "Returns the expected income and expenses for a future period based on detected recurring patterns and scheduled payments. " +
        "Use for: 'what does my cashflow look like next month?', 'how much am I expecting in vs out next month?', " +
        "'show me my income and expense forecast'. Returns separate totals for income and expenses.")]
    public async Task<string> GetCashflowForecast(
        [Description("Start date in YYYY-MM-DD format. Defaults to start of next month.")] string? dateFrom,
        [Description("End date in YYYY-MM-DD format. Defaults to end of next month.")] string? dateTo)
    {
        var now          = DateTimeOffset.UtcNow;
        var nextMonthStart = new DateTimeOffset(now.Year, now.Month, 1, 0, 0, 0, TimeSpan.Zero).AddMonths(1);
        var nextMonthEnd   = nextMonthStart.AddMonths(1).AddDays(-1);

        var from = TryParseDate(dateFrom) ?? nextMonthStart;
        var to   = TryParseDate(dateTo)   ?? nextMonthEnd;

        try
        {
            // API ENHANCEMENT PROPOSAL #E:
            // CFA /upcoming/series currently only aggregates by AccountId.
            // Proposal: add 'aggregationProperty=CategoryType' option so a single call returns
            // { Income: totalAmount, Expenses: totalAmount } per date range.
            // Until then, we make two parallel calls filtered by categoryType.

            var expensesTask = cashflowClient.User.Cashflow.V2.Upcoming.GetAsync(req =>
            {
                req.QueryParameters.DateFrom      = from;
                req.QueryParameters.DateTo        = to;
                req.QueryParameters.PaymentStatus = "Open";
                req.QueryParameters.CategoryTypes = "Expenses";
                req.QueryParameters.Sources       = "Detected,ScheduledPayment,Invoice";
                req.QueryParameters.Take          = 500;
            });

            var incomeTask = cashflowClient.User.Cashflow.V2.Upcoming.GetAsync(req =>
            {
                req.QueryParameters.DateFrom      = from;
                req.QueryParameters.DateTo        = to;
                req.QueryParameters.PaymentStatus = "Open";
                req.QueryParameters.CategoryTypes = "Income";
                req.QueryParameters.Sources       = "Detected,ScheduledPayment";
                req.QueryParameters.Take          = 100;
            });

            await Task.WhenAll(expensesTask, incomeTask);

            var expenses = expensesTask.Result?.Data ?? [];
            var income   = incomeTask.Result?.Data   ?? [];

            // Group by currency for multi-currency safety
            var expensesByCurrency = expenses
                .GroupBy(e => e.CurrencyCode ?? "EUR")
                .Select(g => new
                {
                    currency   = g.Key,
                    total      = g.Sum(e => Math.Abs(e.AmountInCurrency ?? 0)),
                    count      = g.Count(),
                    items      = g.Select(e => new { name = e.Text, amount = Math.Abs(e.AmountInCurrency ?? 0), date = e.Date?.ToString("yyyy-MM-dd") }).ToList()
                });

            var incomeByCurrency = income
                .GroupBy(i => i.CurrencyCode ?? "EUR")
                .Select(g => new
                {
                    currency = g.Key,
                    total    = g.Sum(i => i.AmountInCurrency ?? 0),
                    count    = g.Count(),
                    items    = g.Select(i => new { name = i.Text, amount = i.AmountInCurrency, date = i.Date?.ToString("yyyy-MM-dd") }).ToList()
                });

            return Serialize(new
            {
                status = "ok",
                data   = new
                {
                    expectedExpenses = expensesByCurrency,
                    expectedIncome   = incomeByCurrency
                },
                meta = new
                {
                    forecastFrom = from.ToString("yyyy-MM-dd"),
                    forecastTo   = to.ToString("yyyy-MM-dd"),
                    note = "Forecast is based on open upcoming transactions only. Actual amounts may differ. Once CFA API enhancement #E is implemented (categoryType aggregation in /series), this tool will use a single API call."
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Private helpers
    // ─────────────────────────────────────────────────────────────────────────

    private static DateTimeOffset? TryParseDate(string? value) =>
        DateTimeOffset.TryParse(value, out var d) ? d : null;

    private static string Serialize(object obj) =>
        JsonSerializer.Serialize(obj, new JsonSerializerOptions { WriteIndented = false });

    private static bool IsExpense(dynamic upcoming) =>
        (upcoming.AmountInCurrency ?? 0) < 0 ||
        (upcoming.Details?.ScheduledPayment?.IsReceivable == false);

    private static bool IsIncome(dynamic upcoming) =>
        (upcoming.AmountInCurrency ?? 0) > 0 ||
        (upcoming.Details?.ScheduledPayment?.IsReceivable == true);

    private static (string id, string name, double amount, string currency) MapUpcoming(dynamic u, string type) => (
        id:       u.Id?.ToString() ?? "",
        name:     u.Text ?? u.Details?.ScheduledPayment?.PaymentText ?? "Unknown",
        amount:   Math.Abs((double)(u.AmountInCurrency ?? 0)),
        currency: u.CurrencyCode ?? "EUR"
    );

    /// <summary>
    /// Describes a recurring pattern's frequency in human-readable form.
    /// </summary>
    private static string DescribeFrequency(dynamic? pattern)
    {
        if (pattern == null) return "unknown";
        var monthInterval = (int?)pattern.MonthInterval;
        var weekInterval  = (int?)pattern.WeekInterval;
        return (monthInterval, weekInterval) switch
        {
            (1,  _) => "monthly",
            (3,  _) => "quarterly",
            (6,  _) => "every 6 months",
            (12, _) => "annual",
            (_,  1) => "weekly",
            (_,  2) => "fortnightly",
            _       => pattern.CronExpression ?? "unknown"
        };
    }

    /// <summary>
    /// Estimates monthly cost from a recurring pattern amount and frequency.
    /// </summary>
    private static double EstimateMonthlyAmount(double amount, dynamic? pattern)
    {
        if (pattern == null) return amount;
        var monthInterval = (int?)pattern.MonthInterval ?? 1;
        var weekInterval  = (int?)pattern.WeekInterval;
        if (weekInterval.HasValue)
            return (amount * 52) / 12; // Weekly → monthly estimate
        return monthInterval == 0 ? amount : amount / monthInterval;
    }
}

