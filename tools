    // TOOL 14: get_carbon_footprint
    // Covers query: #60 (what is my carbon footprint from spending?)
    // Uses includeCarbonFootprint=true on transactions — no separate Carbon Action API needed
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("get_carbon_footprint")]
    [Description(
        "Returns the estimated carbon footprint (CO₂ in kg) from the user's spending transactions. " +
        "Use for: 'what is my carbon footprint?', 'how much CO₂ does my spending produce?', " +
        "'show my spending carbon impact'. " +
        "Note: carbon footprint data availability depends on bank and Meniga configuration.")]
    public async Task<string> GetCarbonFootprint(
        [Description("Start date in YYYY-MM-DD format. Defaults to start of current month.")] string? dateFrom = null,
        [Description("End date in YYYY-MM-DD format. Defaults to today.")] string? dateTo = null)
    {
        var now  = DateTimeOffset.UtcNow;
        var from = TryParseDate(dateFrom) ?? new DateTimeOffset(now.Year, now.Month, 1, 0, 0, 0, TimeSpan.Zero);
        var to   = TryParseDate(dateTo)   ?? now;

        try
        {
            // Use includeCarbonFootprint=true on the transactions endpoint —
            // this is more efficient than the Carbon Action API which is for offsetting projects.
            var response = await userApiClient.User.Core.V1.Transactions.GetAsync(req =>
            {
                req.QueryParameters.OriginalPeriodFrom      = from;
                req.QueryParameters.OriginalPeriodTo        = to;
                req.QueryParameters.IncludeCarbonFootprint  = true;
                req.QueryParameters.AmountTo                = -0.01; // Expenses only
                req.QueryParameters.Take                    = 1000;
            });

            var transactions = response?.Data ?? [];
            var withCarbon   = transactions.Where(t => t.CarbonFootprint.HasValue && t.CarbonFootprint > 0).ToList();

            if (withCarbon.Count == 0)
                return Serialize(new
                {
                    status = "empty",
                    meta   = new
                    {
                        message    = "No carbon footprint data found for this period.",
                        disclaimer = "Carbon footprint data requires this enrichment to be enabled by your bank. Not all transactions may have carbon data."
                    }
                });

            // Group by category for breakdown
            var byCategoryId = withCarbon
                .Where(t => t.CategoryId.HasValue)
                .GroupBy(t => t.CategoryId!.Value)
                .Select(g => new
                {
                    categoryId      = g.Key,
                    totalCarbonKg   = g.Sum(t => t.CarbonFootprint ?? 0),
                    transactionCount = g.Count()
                })
                .OrderByDescending(c => c.totalCarbonKg)
                .ToList();

            var totalCarbonKg = withCarbon.Sum(t => t.CarbonFootprint ?? 0);

            return Serialize(new
            {
                status = "ok",
                data   = new
                {
                    totalCarbonKg        = Math.Round(totalCarbonKg, 2),
                    transactionsWithData = withCarbon.Count,
                    transactionsTotal    = transactions.Count,
                    coveragePct          = transactions.Count > 0
                        ? Math.Round((double)withCarbon.Count / transactions.Count * 100, 1)
                        : 0,
                    byCategory = byCategoryId
                },
                meta = new
                {
                    dateFrom   = from.ToString("yyyy-MM-dd"),
                    dateTo     = to.ToString("yyyy-MM-dd"),
                    unit       = "kg CO₂",
                    disclaimer = $"Carbon data covers {(transactions.Count > 0 ? Math.Round((double)withCarbon.Count / transactions.Count * 100, 1) : 0)}% of transactions. Not all merchants have carbon footprint data."
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 15: list_uncategorised_transactions
    // Covers query: #59 (help me categorise my uncategorised transactions)
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("list_uncategorised_transactions")]
    [Description(
        "Returns transactions that have no category assigned. " +
        "Use for: 'help me categorise my uncategorised transactions', " +
        "'some transactions have no category', 'sort out my untagged transactions'. " +
        "Returns a list the user can review to assign categories.")]
    public async Task<string> ListUncategorisedTransactions(
        [Description("Start date in YYYY-MM-DD format. Defaults to last 30 days.")] string? dateFrom = null,
        [Description("End date in YYYY-MM-DD format. Defaults to today.")] string? dateTo = null,
        [Description("Maximum number of uncategorised transactions to return. Default: 50.")] int limit = 50)
    {
        var now  = DateTimeOffset.UtcNow;
        var from = TryParseDate(dateFrom) ?? now.AddDays(-30);
        var to   = TryParseDate(dateTo)   ?? now;

        try
        {
            var response = await userApiClient.User.Core.V1.Transactions.GetAsync(req =>
            {
                req.QueryParameters.OriginalPeriodFrom = from;
                req.QueryParameters.OriginalPeriodTo   = to;
                req.QueryParameters.OnlyUncategorized  = true; // Direct API filter — no post-processing
                req.QueryParameters.Take               = limit;
                req.QueryParameters.Sort               = "-Date";
            });

            var transactions = response?.Data ?? [];

            if (transactions.Count == 0)
                return Serialize(new { status = "empty", data = new { transactions = Array.Empty<object>() }, meta = new { message = "No uncategorised transactions found for this period." } });

            var mapped = transactions.Select(t => new
            {
                id     = t.Id,
                date   = t.Date?.ToString("yyyy-MM-dd"),
                amount = t.Amount,
                currency = t.Currency,
                text   = t.Text,
                merchantId = t.MerchantId,
                // Include detected categories if uncertain categorisation exists — helpful for user to choose
                suggestedCategories = t.DetectedCategories?.OrderByDescending(d => d.Score).Take(3).Select(d => new { d.CategoryId, d.Score })
            }).ToList();

            return Serialize(new
            {
                status = "ok",
                data   = new { transactions = mapped },
                meta   = new
                {
                    count    = mapped.Count,
                    dateFrom = from.ToString("yyyy-MM-dd"),
                    dateTo   = to.ToString("yyyy-MM-dd"),
                    note     = "suggestedCategories contains Meniga's auto-detected category candidates with confidence scores. Use these to guide the user's categorisation choices."
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Private helpers
    // ─────────────────────────────────────────────────────────────────────────

    private static DateTimeOffset? TryParseDate(string? value) =>
        DateTimeOffset.TryParse(value, out var d) ? d : null;

    private static string Serialize(object obj) =>
        JsonSerializer.Serialize(obj, new JsonSerializerOptions { WriteIndented = false });
