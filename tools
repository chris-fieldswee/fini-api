transaction.Text.Contains("P2P"
, StringComparison.OrdinalIgnoreCase) ||
transaction.Text.Contains("Mobile transfer"
,
StringComparison.OrdinalIgnoreCase)))
{
confidence = "MEDIUM";
transferType = "Bank Transfer";
}
// MEDIUM confidence: Has transfer-related tags
else if (transaction.Tags != null &&
transaction.Tags.Any(tag =>
tag.Contains("transfer"
, StringComparison.OrdinalIgnoreCase) ||
tag.Contains("personal"
, StringComparison.OrdinalIgnoreCase) ||
tag.Contains("p2p"
, StringComparison.OrdinalIgnoreCase)))
{
confidence = "MEDIUM";
transferType = "Personal Transfer";
}
// LOW confidence: Just name match in text (could be payment TO them, not FROM)
else if (transaction.Text != null &&
transaction.Text.Contains(senderName, StringComparison.OrdinalIgnoreCase))
{
confidence = "LOW";
transferType = "Possible Transfer";
}
else
{
// Skip - no transfer indicators
continue;
}
transferCandidates.Add((transaction, confidence, transferType));
}
// Handle no results
if (transferCandidates.Count == 0)
{
return $"No incoming transfers found from '{senderName}'
.
";
}
// Build formatted output
var result = new StringBuilder();
result.AppendLine($"Incoming Transfers from \"{senderName}\":");
result.AppendLine("
---
");
