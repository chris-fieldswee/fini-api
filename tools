if (transaction.Tags != null && transaction.Tags.Count > 0)
{
result.AppendLine($"Tags: {string.Join("
,
"
, transaction.Tags)}");
}
// Comments (if available)
if (transaction.Comments != null && transaction.Comments.Count > 0)
{
result.AppendLine("Comments:");
