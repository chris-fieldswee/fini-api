var totalAmount = sortedTransactions.Sum(t => t.Amount ?? 0);
var totalIncoming = sortedTransactions.Where(t => t.Amount > 0).Sum(t => t.Amount ?? 0);
var totalOutgoing = sortedTransactions.Where(t => t.Amount < 0).Sum(t => t.Amount ?? 0);
