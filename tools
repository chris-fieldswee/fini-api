}
// Show tags if available
if (transaction.Tags != null && transaction.Tags.Count > 0)
{
result.AppendLine($"Tags: {string.Join("
,
"
, transaction.Tags)}");
}
// Show comments if available
if (transaction.Comments != null && transaction.Comments.Count > 0)
{
result.AppendLine("Comments:");
foreach (var comment in transaction.Comments)
{
result.AppendLine($" • {comment.Comment}");
}
}
// Show status
var status = transaction.IsUncleared ?? false ? "Pending" : "Completed";
