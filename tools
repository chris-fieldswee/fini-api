                // Compute relative position
                vsMedianPct     = c.PeerMedian > 0 ? Math.Round(((c.UserAmount - c.PeerMedian) / c.PeerMedian) * 100, 1) : (double?)null,
                position        = c.UserAmount > c.PeerAverage ? "above_average" : "below_average",
