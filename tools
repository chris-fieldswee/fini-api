using System.ComponentModel;
using System.Text.Json;
using Meniga.Clients.UserApi;
using Microsoft.SemanticKernel;

namespace Meniga.AI.Plugins;

/// <summary>
/// Provides tools for CORE API endpoints not previously covered:
/// Net worth, life goals, merchant ranking, peer comparison, carbon footprint,
/// and uncategorised transaction review.
/// </summary>
public sealed class CoreInsights(UserApiClient userApiClient)
{
    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 10: get_net_worth
    // Covers query: #24 (what is my net worth?)
    // API enhancement proposal #H: NetWorth endpoint to include account breakdown inline
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("get_net_worth")]
    [Description(
        "Returns the user's current net worth — total assets minus total liabilities. " +
        "Use for: 'what is my net worth?', 'what are my total assets and debts?', " +
        "'show my overall financial position'. Returns asset and liability totals with account breakdown.")]
    public async Task<string> GetNetWorth()
    {
        try
        {
            // API ENHANCEMENT PROPOSAL #H:
            // GET /user/core/v1/networth currently returns a top-level NetWorthBalanceModel
            // with total assets and liabilities but requires a separate GET /accounts call
            // to show the per-account breakdown.
            // Proposal: add an optional 'includeAccountBreakdown=true' parameter that embeds
            // account-level balances grouped by NetWorthTypeEnum (Asset/Liability) in the response.
            // Until then, we make two parallel calls.

            var netWorthTask = userApiClient.User.Core.V1.Networth.GetAsync();
            var accountsTask = userApiClient.User.Core.V1.Accounts.GetAsync();

            await Task.WhenAll(netWorthTask, accountsTask);

            var netWorth = netWorthTask.Result?.Data;
            var accounts = accountsTask.Result?.Data ?? [];

            if (netWorth == null)
                return Serialize(new { status = "empty", meta = new { message = "Net worth data not available." } });

            // Group accounts by asset vs liability
            var assets = accounts
                .Where(a => (a.Balance ?? 0) >= 0 &&
                            a.AccountCategory is not "Credit" and not "Loan")
                .Select(a => new { a.Name, balance = a.Balance, currency = a.CurrencyCode, type = a.AccountCategory })
                .ToList();

            var liabilities = accounts
                .Where(a => a.AccountCategory is "Credit" or "Loan" || (a.Balance ?? 0) < 0)
                .Select(a => new { a.Name, balance = Math.Abs(a.Balance ?? 0), currency = a.CurrencyCode, type = a.AccountCategory })
                .ToList();

            return Serialize(new
            {
                status = "ok",
                data   = new
                {
                    netWorth     = netWorth.Balance,
                    totalAssets  = netWorth.TotalAssets,
                    totalLiabilities = netWorth.TotalLiabilities,
                    currency     = netWorth.CurrencyCode,
                    assetAccounts     = assets,
                    liabilityAccounts = liabilities
                },
                meta = new
                {
                    note = "Net worth = total assets minus total liabilities. Figures are in user's base currency. Once API enhancement #H is implemented, account breakdown will be returned in a single call."
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // TOOL 11: get_life_goal_progress
    // Covers queries: #40 (how much to save to reach goal?), #41 (am I on track for goal?)
    // ─────────────────────────────────────────────────────────────────────────

    [KernelFunction("get_life_goal_progress")]
    [Description(
        "Returns progress towards the user's savings goals. " +
        "Use for: 'how am I progressing towards my savings goal?', 'how much more do I need to save?', " +
        "'am I on track for my savings target?', 'how long until I reach my goal?'. " +
        "Returns current progress, amount remaining, and projected completion date if on current trajectory.")]
    public async Task<string> GetLifeGoalProgress(
        [Description("Optional goal name or partial name to filter to a specific goal. Returns all goals if omitted.")] string? goalName = null)
    {
        try
        {
            var response = await userApiClient.User.Core.V1.Lifegoals.GetAsync();
            var goals    = response?.Data ?? [];

            if (goals.Count == 0)
                return Serialize(new { status = "empty", data = new { goals = Array.Empty<object>() }, meta = new { message = "No savings goals found." } });

            // Filter by name if provided
            if (!string.IsNullOrWhiteSpace(goalName))
                goals = goals.Where(g => g.Name?.Contains(goalName, StringComparison.OrdinalIgnoreCase) == true).ToList();

            if (goals.Count == 0)
                return Serialize(new { status = "empty", meta = new { message = $"No goal found matching '{goalName}'." } });

            var mapped = goals.Select(g =>
            {
                var targetAmount  = g.TargetAmount ?? 0;
                var currentAmount = g.CurrentAmount ?? 0;
                var remaining     = Math.Max(0, targetAmount - currentAmount);
                var progressPct   = targetAmount > 0 ? (currentAmount / targetAmount) * 100 : 0;

                // Estimate monthly saving rate from goal account history if available
                var monthlyRate = g.MonthlySavingsAmount ?? 0;

                // Project completion: remaining / monthlyRate = months needed
                var monthsToComplete = (monthlyRate > 0 && remaining > 0)
                    ? Math.Ceiling(remaining / monthlyRate)
                    : (double?)null;

                var projectedCompletionDate = monthsToComplete.HasValue
                    ? DateTimeOffset.UtcNow.AddMonths((int)monthsToComplete.Value).ToString("yyyy-MM-dd")
                    : null;

                var targetDate = g.TargetDate?.ToString("yyyy-MM-dd");

                // Is the user on track? Compare projected vs target date
                bool? isOnTrack = null;
                if (projectedCompletionDate != null && targetDate != null)
                {
                    isOnTrack = string.Compare(projectedCompletionDate, targetDate, StringComparison.Ordinal) <= 0;
                }

                return new
                {
                    id                     = g.Id,
                    name                   = g.Name,
                    targetAmount,
                    currentAmount,
                    remainingAmount        = remaining,
                    progressPercentage     = Math.Round(progressPct, 1),
                    currency               = g.CurrencyCode,
                    targetDate,
                    estimatedMonthlyRate   = monthlyRate,
                    projectedCompletionDate,
                    isOnTrack,
                    status                 = g.Status?.ToString()
                };
            }).ToList();

            return Serialize(new
            {
                status = "ok",
                data   = new { goals = mapped },
                meta   = new
                {
                    count = mapped.Count,
                    note  = "projectedCompletionDate is estimated from MonthlySavingsAmount on the goal. If not set, it will be null."
                }
            });
        }
        catch (Exception ex)
        {
            return Serialize(new { status = "error", error = new { reason = "api_failure", message = ex.Message } });
        }
    }

