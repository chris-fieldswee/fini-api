{
// Validate input
if (string.IsNullOrWhiteSpace(senderName))
{
return "Please provide a sender name to search for.
";
}
// Query transactions API for incoming transactions matching the sender name
var response = await
userApiClient.User.Core.V1.Transactions.GetAsync(requestConfiguration =>
{
// Search for incoming transactions (positive amounts only)
requestConfiguration.QueryParameters.AmountFrom = 0.01; // Only positive (incoming)
// Search across multiple fields where sender info might appear
requestConfiguration.QueryParameters.SearchText = senderName;
requestConfiguration.QueryParameters.SearchTextFields =
"text,originalText,parsedData.sender
_
name,parsedData.beneficiary_
name,parsedData.counterp
arty_
name";
requestConfiguration.QueryParameters.UseAccentInsensitiveSearch = true;
// Exclude merchant transactions (transfers are typically person-to-person)
requestConfiguration.QueryParameters.IsMerchant = false;
// Limit results
requestConfiguration.QueryParameters.Take = 50;
// Sort by date descending (most recent first)
requestConfiguration.QueryParameters.Sort = "
-Date";
});
var transactions = response?.Data ?? [];
// Filter and score transactions based on transfer indicators
var transferCandidates = new List<(TransactionModel Transaction, string Confidence,
string TransferType)>();
foreach (var transaction in transactions)
{
// Skip if no amount or date
if (!transaction.Amount.HasValue || !transaction.Date.HasValue)
continue;
// Double-check it's incoming (positive amount)
if (transaction.Amount.Value <= 0)
continue;
string confidence;
string transferType;
// HIGH confidence: Has counterparty account identifier
if (!string.IsNullOrWhiteSpace(transaction.CounterpartyAccountIdentifier))
{
confidence = "HIGH";
transferType = "Person-to-Person Transfer";
}
// HIGH confidence: ParsedData contains sender info
else if (transaction.ParsedData != null &&
transaction.ParsedData.Any(pd =>
pd.Key != null &&
(pd.Key.Contains("sender"
