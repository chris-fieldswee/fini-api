category")]
[Description("Gets expenses for a specific category and time period with monthly
breakdown.
")]
public async Task<string> GetExpensesByCategory(
[Description("Start date in YYYY-MM-DD format")] string startDate,
[Description("End date in YYYY-MM-DD format")] string endDate,
[Description("Category to filter by")] string category)
{
// Parse dates
if (!DateTimeOffset.TryParse(startDate, out var periodFrom))
{
// Default to last year if not specified
var now = DateTimeOffset.UtcNow;
periodFrom = new DateTimeOffset(now.Year - 1, 1, 1, 0, 0, 0, TimeSpan.Zero);
}
if (!DateTimeOffset.TryParse(endDate, out var periodTo))
{
// Default to end of last year if not specified
var now = DateTimeOffset.UtcNow;
periodTo = new DateTimeOffset(now.Year - 1, 12, 31, 23, 59, 59, TimeSpan.Zero);
}
// Fetch all categories to find matching ones
var categoriesResponse = await userApiClient.User.Core.V1.Categories.GetAsync();
var allCategories = categoriesResponse?.Data ?? [];
// Search for categories matching the requested category name (fuzzy match)
var matchingCategories = allCategories
.Where(c => c.Name != null && c.Name.Contains(category,
StringComparison.OrdinalIgnoreCase))
.ToList();
// Also check child categories
foreach (var cat in allCategories.Where(c => c.Children != null))
{
var matchingChildren = cat.Children!
.Where(c => c.Name != null && c.Name.Contains(category,
StringComparison.OrdinalIgnoreCase))
.ToList();
matchingCategories.AddRange(matchingChildren);
}
var categoryIds = matchingCategories
.Select(c => c.Id)
.Where(id => id.HasValue)
.Select(id => (int?)id!.Value)
.Distinct()
.ToList();
if (categoryIds.Count == 0)
{
return $"No categories found matching '{category}'
.
";
}
// Fetch transactions using GetAsync and manually aggregate by month
// Note: GetAsync doesn't support array filtering directly, so we'll need to fetch
// transactions and filter by category IDs in memory, or make multiple calls
// For simplicity, we'll fetch all transactions in the period and filter
var response = await
userApiClient.User.Core.V1.Transactions.GetAsync(requestConfiguration =>
{
requestConfiguration.QueryParameters.PeriodFrom = periodFrom;
requestConfiguration.QueryParameters.PeriodTo = periodTo;
// Filter for expense transactions (negative amounts only)
requestConfiguration.QueryParameters.AmountTo = -0.01;
// Set a reasonable limit to avoid performance issues
requestConfiguration.QueryParameters.Take = 500;
});
var transactions = response?.Data ?? [];
if (transactions.Count == 0)
{
return $"No expenses found for category '{category}' in the specified period.
";
}
// Filter transactions by matching category IDs
var filteredTransactions = transactions
.Where(t => t.CategoryId.HasValue && categoryIds.Contains(t.CategoryId.Value))
.Where(t => t.Date.HasValue && t.Amount.HasValue)
.ToList();
if (filteredTransactions.Count == 0)
{
return $"No expenses found for category '{category}' in the specified period.
";
}
// Group transactions by month and calculate monthly totals
var monthlyGroups = filteredTransactions
.GroupBy(t => new { t.Date!.Value.Year, t.Date!.Value.Month })
.Select(g => new
{
Date = new DateTimeOffset(g.Key.Year, g.Key.Month, 1, 0, 0, 0, TimeSpan.Zero),
Total = g.Sum(t => Math.Abs(t.Amount!.Value))
})
.OrderBy(m => m.Date)
.ToList();
// Calculate total and build monthly breakdown
var result = new StringBuilder();
var categoryNames = string.Join("
,
"
, matchingCategories.Select(c => c.Name).Distinct());
result.AppendLine($"Period: {periodFrom:yyyy-MM-dd} to {periodTo:yyyy-MM-dd}");
result.AppendLine($"Category: {categoryNames}");
// Calculate total
var total = monthlyGroups.Sum(m => m.Total);
result.AppendLine($"Total Spent: {total:N0} EUR");
result.AppendLine("
---
");
result.AppendLine("Monthly Breakdown:");
// Display each month
foreach (var monthData in monthlyGroups)
{
if (monthData.Total > 0)
{
result.AppendLine($"{monthData.Date:MMMM yyyy}: {monthData.Total:N0} EUR");
}
}
return result.ToString();
}
[KernelFunction("get
_
expenses
_
summary")]
[Description("Gets a summary of expenses for a specified period with category breakdown.
")]
public async Task<string> GetExpensesSummary(
[Description("Start date in YYYY-MM-DD format")] string startDate,
[Description("End date in YYYY-MM-DD format")] string endDate)
{
// Parse dates
if (!DateTimeOffset.TryParse(startDate, out var periodFrom))
{
periodFrom = new DateTimeOffset(DateTime.UtcNow.Year, 1, 1, 0, 0, 0,
TimeSpan.Zero);
}
if (!DateTimeOffset.TryParse(endDate, out var periodTo))
{
periodTo = DateTimeOffset.UtcNow;
}
// Fetch all expense categories
var categoriesResponse = await userApiClient.User.Core.V1.Categories.GetAsync();
var allCategories = categoriesResponse?.Data ?? [];
// Filter for expense categories only
var expenseCategories = allCategories
.Where(c => c.CategoryType == CategoryTypeEnum.Expenses)
.ToList();
if (expenseCategories.Count == 0)
return "No expense categories found.
";
{
}
// Build series selectors for each expense category
var seriesSelectors = new List<TransactionSeriesSelector>();
var categoryMap = new Dictionary<int, string>();
foreach (var category in expenseCategories)
{
if (category.Id.HasValue)
{
seriesSelectors.Add(new TransactionSeriesSelector
{
Filter = new TransactionFilter
{
CategoryIds = [category.Id.Value]
}
});
categoryMap[seriesSelectors.Count - 1] = category.Name ?? "Unknown";
}
}
// Create transaction series request
var request = new TransactionSeriesRequest
{
TransactionFilter = new TransactionFilter
{
PeriodFrom = periodFrom,
PeriodTo = periodTo
},
{
Options = new TransactionSeriesOptions
OverTime = false // Get total for the period, not time-series
},
SeriesSelectors = seriesSelectors
};
var response = await userApiClient.User.Core.V1.Transactions.Series.PostAsync(request);
if (response?.Data == null || response.Data.Count == 0)
return "No expense data found for the specified period.
";
{
}
// Aggregate results by category
var categoryExpenses = new Dictionary<string, double>();
double totalExpenses = 0;
for (int i = 0; i < response.Data.Count && i < seriesSelectors.Count; i++)
{
var series = response.Data[i];
var categoryName = categoryMap.ContainsKey(i) ? categoryMap[i] : "Other";
var categoryTotal = Math.Abs(series.Values?[0].TotalNegative ?? 0);
if (categoryTotal > 0)
{
categoryExpenses[categoryName] = categoryTotal;
totalExpenses += categoryTotal;
}
}
// Calculate number of months for average
var monthsDiff = ((periodTo.Year - periodFrom.Year) * 12) + periodTo.Month -
periodFrom.Month;
var numberOfMonths = Math.Max(1, monthsDiff);
var monthlyAverage = totalExpenses / numberOfMonths;
// Build output - sort by amount descending
var result = new StringBuilder();
result.AppendLine($"Period: {periodFrom:yyyy-MM-dd} to {periodTo:yyyy-MM-dd}");
result.AppendLine($"Total Expenses: {totalExpenses:N0} EUR");
result.AppendLine("
---
");
result.AppendLine("Category Breakdown:");
foreach (var kvp in categoryExpenses.OrderByDescending(x => x.Value))
{
var percentage = (kvp.Value / totalExpenses) * 100;
result.AppendLine($"{kvp.Key}: {kvp.Value:N0} EUR ({percentage:F1}%)");
}
result.AppendLine("
---
");
}
}
result.AppendLine($"Monthly Average: {monthlyAverage:N0} EUR");
result.AppendLine($"Number of Months: {numberOfMonths}");
return result.ToString();

